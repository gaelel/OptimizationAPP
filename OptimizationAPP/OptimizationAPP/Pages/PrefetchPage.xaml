<Page x:Class="OptimizationAPP.Pages.PrefetchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OptimizationAPP.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PrefetchPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"  Margin="10">
            <TextBlock Text="Prefetch" FontSize="50" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Elimina los archivos temporales almacenados en prefetch." 
                       FontSize="20" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            <Button x:Name="btnIniciar" Content="LIMPIAR" Width="150" Height="35" HorizontalAlignment="Center" Margin="0,20,0,0" Click="btnIniciar_Click"/>

        </StackPanel>
        <Button x:Name="btnSiguiente" Content="SIGUIENTE" Grid.Row="1" Width="100" Height="35" HorizontalAlignment="Right" Margin="0,0,5,5" Click="btnSiguiente_Click"/>
        <Button x:Name="btnAnterior" Content="ANTERIOR" Grid.Row="1" Width="100" Height="35" HorizontalAlignment="Left" Margin="5,0,0,5" Click="btnAnterior_Click"/>
    </Grid>
</Page>
