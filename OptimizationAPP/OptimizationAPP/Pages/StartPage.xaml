<Page x:Class="OptimizationAPP.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:OptimizationAPP"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="StartPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"  Margin="10">
            <TextBlock Text="Optimization App" FontSize="50" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Welcome to the Optimization App! This application is designed to help you optimize your system's performance by cleaning up temporary files, managing disk space, and providing access to advanced settings." 
                       FontSize="20" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,15,0,0"/>

        </StackPanel>
        <Button x:Name="btnSiguiente" Content="SIGUIENTE" Grid.Row="1" Width="100" Height="35" HorizontalAlignment="Right" Click="btnSiguiente_Click" Margin="0,0,5,5"/>
    </Grid>

</Page>
